{
  "name": "ally-fix",
  "version": "0.0.0",
  "private": true,
  "description": "AllyFix — an open-source accessibility auditor that explains WHY each WCAG issue matters and HOW to fix it, right in your code.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @ally-fix/db db:generate",
    "db:migrate": "pnpm --filter @ally-fix/db db:migrate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
