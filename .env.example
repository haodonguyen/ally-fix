# =============================================================================
# AllyFix — environment template
# Copy this file to `.env` and fill in the values. NEVER commit a real `.env`.
# This project is bring-your-own-key: no API keys are ever hardcoded or logged.
# =============================================================================

# --- Core services ----------------------------------------------------------
# PostgreSQL connection string (Drizzle). Matches the docker-compose `postgres` service.
DATABASE_URL=postgres://allyfix:allyfix@localhost:5432/allyfix

# Redis connection string (BullMQ queue + result cache). Matches docker-compose `redis`.
REDIS_URL=redis://localhost:6379

# --- Web app ----------------------------------------------------------------
# Public base URL of the web app (used for shareable report links).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- LLM provider selection -------------------------------------------------
# Which provider the LLM layer uses. One of: ollama | groq | gemini
# `ollama` is the default for local/self-hosted runs and needs no API key.
LLM_PROVIDER=ollama

# Ollama (local, free). Only used when LLM_PROVIDER=ollama.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Groq (bring-your-own-key). Only used when LLM_PROVIDER=groq.
# User-supplied keys live only in-session; they are never written to the DB.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (bring-your-own-key). Only used when LLM_PROVIDER=gemini.
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# How long a cached LLM analysis stays valid, in seconds (default 30 days).
# Results are cached in Redis by provider + model + rule + HTML pattern.
LLM_CACHE_TTL_SECONDS=2592000

# --- Cost / rate limiting (hosted demo only) --------------------------------
# Per-IP daily audit limit for the maintainer-hosted free tier. 0 = unlimited (self-host).
DAILY_AUDIT_LIMIT_PER_IP=0

# --- Runtime ----------------------------------------------------------------
NODE_ENV=development

# Max time the worker waits for a page to load before failing the scan, in ms.
SCAN_TIMEOUT_MS=30000
